# =============================================================================
# Environment Selection (Multi-Environment Settings Architecture)
# =============================================================================
# Options: development, staging, production, test
# Default: development
# See: docs/adrs/adr-029-multi-environment-settings.md
DJANGO_ENV=development

# =============================================================================
# Django Configuration
# =============================================================================
# SECURITY: SECRET_KEY is REQUIRED and must be unique
# NEVER use the default value in production!
# Generate a new key with:
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
#
# SECURITY FIX (Critical Issue #3 - CVSS 7.3):
# - Default SECRET_KEY removed to prevent accidental production deployment
# - Django will refuse to start without a valid SECRET_KEY in .env
# - NEVER commit .env file to version control
SECRET_KEY=  # REQUIRED: Generate with command above
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Options: 'sqlite' or 'postgresql'
DB_ENGINE=postgresql

# PostgreSQL Configuration (when DB_ENGINE=postgresql)
DB_NAME=cv_tailor
DB_USER=cv_tailor_user
DB_PASSWORD=your-secure-password-here
DB_HOST=db  # Use 'db' for Docker, 'localhost' for local development
DB_PORT=5432

# Redis Configuration
CELERY_BROKER_URL=redis://redis:6379/0  # Use 'redis' for Docker, 'localhost' for local
CELERY_RESULT_BACKEND=redis://redis:6379/0

# LLM API Configuration (OpenAI only)
OPENAI_API_KEY=your-openai-api-key-here

# GitHub API Configuration
GITHUB_TOKEN=your-github-token-here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Development Superuser (AUTO-CREATED - DEV ONLY)
# Set these in your local .env file (NOT in docker-compose.yml)
# The superuser will be auto-created on container startup if these are set
#
# ⚠️ SECURITY WARNINGS (High Security Issue #5 - CVSS 6.0):
# - Only works when DEBUG=True (refuses in production)
# - Keep credentials in .env file (git-ignored)
# - NEVER commit .env to version control
# - NEVER hardcode in docker-compose.yml
# - NEVER set these in production environment
# - Change default password immediately after first login
# - Environment variables can be exposed via process listings and container inspection
#
# RECOMMENDATION: Create superuser manually instead:
#   docker-compose exec backend uv run python manage.py createsuperuser
#
# To enable auto-creation (development only), uncomment and set values:
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=your-secure-password-here

# =============================================================================
# AI/LLM Model Strategy (Optional - defaults in settings)
# =============================================================================
# Model selection strategy: cost_optimized, balanced, quality_optimized
# MODEL_SELECTION_STRATEGY=balanced

# Performance tracking
# TRACK_MODEL_PERFORMANCE=True
# OPTIMIZE_FOR_COST=False
# OPTIMIZE_FOR_QUALITY=False

# Budget limits (USD)
# DAILY_LLM_BUDGET=50.0
# MONTHLY_LLM_BUDGET=1000.0
# MAX_USER_DAILY_COST=5.0

# =============================================================================
# LangChain Document Processing (Optional - defaults in settings)
# =============================================================================
# LANGCHAIN_CHUNK_SIZE=1000
# LANGCHAIN_CHUNK_OVERLAP=200
# MAX_CHUNKS_PER_DOCUMENT=50
# SEMANTIC_CHUNKING_THRESHOLD=0.8

# =============================================================================
# ft-030: Anti-Hallucination Improvements (Optional - defaults in settings)
# =============================================================================
# Feature flag to enable/disable verification service
# FT030_VERIFICATION_ENABLED=True

# GPT-5 Configuration (ADR-045)
# Enable GPT-5 reasoning mode for extraction and verification tasks
# FT030_GPT5_ENABLED=True

# Default reasoning effort levels by task type
# Options: low, medium, high
# FT030_REASONING_EXTRACTION=high      # Source attribution extraction
# FT030_REASONING_VERIFICATION=high    # Fact-checking verification
# FT030_REASONING_GENERATION=medium    # Content generation
# FT030_REASONING_RANKING=low          # Artifact ranking

# Confidence Threshold Overrides (ADR-043)
# Default values: HIGH=0.85, MEDIUM=0.70, LOW=0.50
# Only override if you need custom thresholds for your use case
# FT030_THRESHOLD_HIGH=0.85
# FT030_THRESHOLD_MEDIUM=0.70
# FT030_THRESHOLD_LOW=0.50

# Inferred Item Ratio Penalty Threshold
# Trigger confidence penalty if >X% of items are inferred (default: 0.30 = 30%)
# FT030_INFERRED_RATIO_THRESHOLD=0.30

# Verification Performance Settings
# Maximum concurrent verification operations (default: 5)
# FT030_MAX_PARALLEL_VERIFICATIONS=5

# Verification timeout in seconds (default: 30)
# FT030_VERIFICATION_TIMEOUT=30

# =============================================================================
# AWS Configuration (Production/Staging Only)
# =============================================================================
# Only needed when DJANGO_ENV=production or DJANGO_ENV=staging
# Secrets are managed via AWS Secrets Manager in production/staging

# AWS Region
# AWS_REGION=us-west-1

# AWS Secrets Manager secret name
# Production: cv-tailor/production
# Staging: cv-tailor/staging
# AWS_SECRETS_NAME=cv-tailor/production

# CORS allowed origins (comma-separated HTTPS URLs for production)
# Example: https://app.cv-tailor.com,https://www.cv-tailor.com
# CORS_ALLOWED_ORIGINS=

# =============================================================================
# Notes
# =============================================================================
# 1. Never commit .env file to version control
# 2. Production secrets are managed via AWS Secrets Manager (see ADR-031)
# 3. See docs/features/ft-020-production-environment-config.md for details
# 4. Run `docker-compose up -d` to start all services
# 5. Run `docker-compose exec backend uv run python manage.py migrate` to setup database
# 6. Multi-environment settings: development (default), staging, production, test